import time.dateOf
import time.timeBetween
policy "filter content in collection"
permit
    action == "list books";
obligation
	{
		"type" : "jsonContentFilterPredicate",
		"conditions" : [
						{
							"path" : "$.ageRating",
							"type" : "<=",
							"value" : timeBetween(subject.birthday, dateOf(|<time.now>), "years")
						}
					   ]
	}